{
  "assessment_framework": {
    "name": "TKA Matematika SMA/Sederajat",
    "definition": "TKA Matematika mengukur kemampuan murid dalam memahami fakta, konsep, prinsip, dan prosedur matematika, serta kemampuan mereka dalam menerapkan pengetahuan matematika untuk menyelesaikan masalah (problem solving)."
  },
  "content_scope": {
    "description": "Muatan TKA Matematika merujuk pada elemen kurikulum atau materi matematika yang dipelajari murid pada Kurikulum 2013 dan Kurikulum Merdeka.",
    "elements": [
      "Bilangan",
      "Aljabar",
      "Geometri dan Pengukuran",
      "Data dan Peluang",
      "Trigonometri"
    ],
    "notes": "Penggunaan logika matematika diintegrasikan langsung dengan elemen matematika dalam kurikulum. Pengetahuan matematika diukur melalui permasalahan dalam konteks matematika maupun kehidupan sehari-hari, baik pada lingkungan personal, keluarga, maupun lingkungan sekitar secara lokal maupun global."
  },
  "competency_levels": [
    {
      "level": 1,
      "name": "Pengetahuan dan Pemahaman",
      "alias": "Knowing and Understanding",
      "processes": [
        {
          "name": "Menghitung",
          "description": "Melakukan perhitungan berdasarkan prosedur yang mencakup operasi hitung aritmatika (+, −, ×, ÷), operasi aljabar, atau operasi matematika lainnya."
        },
        {
          "name": "Memahami informasi",
          "description": "Memahami informasi dari grafik fungsi, tabel, diagram, infografis, atau bentuk visual lainnya."
        },
        {
          "name": "Mengelompokkan",
          "description": "Mengelompokkan objek berdasarkan fakta, konsep, dan prinsip matematika dalam cakupan sub-elemen."
        },
        {
          "name": "Mengidentifikasi",
          "description": "Melakukan identifikasi terhadap objek menggunakan konsep, fakta, dan prinsip matematika."
        }
      ]
    },
    {
      "level": 2,
      "name": "Aplikasi",
      "alias": "Applying",
      "processes": [
        {
          "name": "Memodelkan",
          "description": "Memodelkan permasalahan kontekstual ke dalam pernyataan matematika."
        },
        {
          "name": "Menerapkan",
          "description": "Menerapkan strategi dan operasi matematika untuk menyelesaikan masalah yang melibatkan konsep dan prosedur matematika yang familiar dan rutin."
        },
        {
          "name": "Menginterpretasikan",
          "description": "Memahami dan menjelaskan makna dari berbagai situasi, kejadian, pernyataan, representasi, atau masalah matematika."
        }
      ]
    },
    {
      "level": 3,
      "name": "Penalaran",
      "alias": "Reasoning",
      "processes": [
        {
          "name": "Menganalisis",
          "description": "Menentukan, menjelaskan, dan menggunakan hubungan beberapa konsep, fakta, prinsip, atau prosedur matematika."
        },
        {
          "name": "Memecahkan masalah",
          "description": "Mengaitkan beberapa konsep, fakta, prinsip, prosedur, dan representasi matematika untuk menyelesaikan permasalahan pada situasi baru."
        },
        {
          "name": "Mengevaluasi",
          "description": "Mengevaluasi alternatif strategi dan solusi dari suatu pemecahan masalah."
        },
        {
          "name": "Menyimpulkan",
          "description": "Menarik kesimpulan yang valid dari informasi, data, atau bukti."
        },
        {
          "name": "Generalisasi",
          "description": "Menyusun pernyataan matematis yang menggambarkan hubungan umum antara konsep, fakta, prinsip, dan prosedur."
        },
        {
          "name": "Menjustifikasi",
          "description": "Memberikan argumen matematis atau langkah/prosedur secara logis untuk mendukung solusi."
        }
      ]
    }
  ],
